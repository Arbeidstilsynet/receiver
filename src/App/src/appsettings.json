{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http": "Warning"
    }
  },
  "API": {
    "Authentication": {
      "DisableAuth": true
    }
  },
  "Domain": {
    "AllowOnlyRegisteredApps": true,
    "RequireAltinnDeletionOnUnsubscribe": true
  },
  "Infrastructure": {
    "DocumentStorageConfiguration": {
      "AuthRequired": true,
      "BucketName": "test-bucket"
    },
    "MaskinportenConfiguration": {
      "CertificatePrivateKey": "<will-be-replaced-at-runtime>",
      "CertificateChain": "<will-be-replaced-at-runtime>",
      "IntegrationId": "<will-be-replaced-at-runtime>",
      "Scopes": ["altinn:serviceowner/instances.read", "altinn:serviceowner/instances.write"]
    }
  }
}
